generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model InverterManufacturer {
  id           String    @id @default(uuid())
  name         String
  country      String?
  website      String?
  contactEmail String?
  contactPhone String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  inverters    Inverter[]  // Relation: One manufacturer can have many inverters
}

model Site {
  id             String     @id @default(uuid())
  name           String
  latitude       Float
  longitude      Float
  region         String
  peakCapacityMw Float
  createdAt      DateTime   @default(now())
  inverters      Inverter[]
}

model Inverter {
  id             String              @id @default(uuid())
  siteId         String
  manufacturerId String?
  name           String
  capacityKw     Float
  status         InverterStatus
  installedAt    DateTime
  alerts         Alert[]
  telemetry      Telemetry[]
  
  site           Site                @relation(fields: [siteId], references: [id])
  manufacturer   InverterManufacturer? @relation(fields: [manufacturerId], references: [id])
}

model Telemetry {
  id         BigInt   @id @default(autoincrement())
  inverterId String
  timestamp  DateTime
  acOutputKw Float
  tempC      Float
  irradiance Float
  status     InverterStatus?
  inverter   Inverter @relation(fields: [inverterId], references: [id])

  @@unique([inverterId, timestamp])
  @@index([timestamp])
}

model Alert {
  id         String        @id @default(uuid())
  inverterId String
  message    String
  severity   AlertSeverity
  status     AlertStatus   @default(Open)
  createdAt  DateTime      @default(now())
  inverter   Inverter      @relation(fields: [inverterId], references: [id])
}

enum AlertSeverity {
  Warning
  Critical
}

enum AlertStatus {
  Open
  Acknowledged
  Resolved
}

enum InverterStatus {
  Online
  Degraded
  Critical
  Offline
}

enum SiteHealth {
  Good
  Warning
  Critical
  Unknown
}
